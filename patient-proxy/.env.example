# Copy to .env (gitignored) and fill in. Loaded by docker-compose (env_file).

# --- Upstream llama.cpp / Qwen (OpenAI-compatible), WITHOUT trailing /chat/completions ---
# Prefer the INTERNAL docker address of your llama.cpp service, e.g. http://llamacpp:8080/v1
# (so the proxy->model hop never leaves the docker network, and llama.cpp can be internal-only).
QWEN_BASE_URL=http://llamacpp:8080/v1
QWEN_API_KEY=sk-...                     # your llama.cpp key — stays server-side only
QWEN_MODEL=Qwen3.6-35B-A3B-BF16         # pinned; clients cannot request other models

# --- Who may call this proxy (comma-separated exact origins). Empty = allow all (DEV ONLY). ---
ALLOW_ORIGIN=https://your-book-origin

# --- Optional per-cohort token the book sends as the X-Patient-Access header. ---
# Discoverable in the book client — a revocation/rate-limit handle, NOT a secret. Leave blank to disable.
ACCESS_TOKEN=

# --- Abuse controls ---
RATE_LIMIT_RPM=20        # requests per minute per client IP
MAX_TOKENS_CAP=600       # hard ceiling on max_tokens
MAX_MESSAGES=40          # reject conversations longer than this
MAX_BODY_BYTES=65536     # reject oversized request bodies

# --- Qwen3.6 is a reasoning model: leave OFF or content comes back empty ---
QWEN_ENABLE_THINKING=false

PORT=8787
