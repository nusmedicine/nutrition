# Copy to .env (gitignored) and fill in. Only needed for the HOSTED column.
# The LOCAL (WebLLM) column works with none of this set.

# Base URL of your OpenAI-compatible endpoint, WITHOUT a trailing /chat/completions.
# e.g. https://your-host/v1  (Open WebUI-style hosts use https://your-host/api)
QWEN_BASE_URL=

# Bearer token / API key for the endpoint.
QWEN_API_KEY=

# Model id the endpoint expects (what you'd put in the "model" field).
QWEN_MODEL=

# DEV-ONLY: set to true to skip TLS certificate verification for the proxy's
# calls to QWEN_BASE_URL. Only needed if the endpoint's cert is expired/self-signed.
# Leave unset/false normally — the proper fix is a valid cert on the endpoint
# (an expired cert also breaks students' browsers if we deploy the hosted path).
# QWEN_INSECURE_TLS=false
